# ─── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database (Postgres) ───────────────────────────────────────────────
# Matches docker-compose.yml below.
DATABASE_URL=postgresql://oggvo:oggvo@localhost:5432/oggvo_dev

# ─── Redis (BullMQ queues + cache) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900            # 15 min
JWT_REFRESH_TTL=2592000       # 30 days

# ─── Object storage (S3 / MinIO locally) ───────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=oggvo-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ─── Email (Mailpit locally; SendGrid in prod) ─────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SENDGRID_API_KEY=

# ─── Integrations (fill per environment) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Secret used to encrypt third-party OAuth tokens at rest (integrations vault)
INTEGRATIONS_ENCRYPTION_KEY=dev-32-byte-key-change-me-please!!

# ─── App URLs ──────────────────────────────────────────────────────────
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
